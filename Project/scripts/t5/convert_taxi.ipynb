   "source": [
    "import geopandas as gpd\n",
    "\n",
    "gdf = gpd.read_file(\"taxi_zones.shp\")\n",
    "gdf = gdf.to_crs(\"EPSG:4326\")\n",
    "gdf[\"wkt\"] = gdf.geometry.to_wkt()\n",
    "\n",
    "cols = [\"LocationID\", \"borough\", \"zone\", \"wkt\"]\n",
    "\n",
    "gdf[cols].rename(columns={\n",
    "    \"LocationID\": \"location_id\"\n",
    "}).to_csv(\"taxi_zones_wkt.csv\", index=False)"
   ]
  }
 ],
